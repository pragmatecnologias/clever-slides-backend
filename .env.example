NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pastor_decks
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=pastor_decks

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM
LM_STUDIO_URL=http://localhost:1234/v1
OPENAI_API_KEY=

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Media Generation APIs
ELEVENLABS_API_KEY=
LOCAL_TTS_API_URL=http://localhost:5500
LOCAL_TTS_GENERATE_PATH=/api/tts
LOCAL_TTS_VOICES_PATH=/api/voices
LOCAL_TTS_DEFAULT_VOICE=alloy
LOCAL_TTS_MODEL=kokoro
LOCAL_TTS_TIMEOUT_MS=60000
SUNO_API_KEY=
SUNO_API_BASE_URL=https://api.sunoapi.org
SUNO_MODEL=V4_5ALL
SUNO_TIMEOUT_MS=60000
SUNO_POLL_INTERVAL_MS=4000
SUNO_MAX_POLL_ATTEMPTS=75
# Local fast-test mode (skips external Suno and returns 2 mock tracks quickly)
SUNO_MOCK_MODE=true
SUNO_MOCK_DELAY_MS=1000
# Optional explicit callback endpoint. If empty, callback URL is derived from API_BASE_URL.
# Must be publicly reachable in production.
SUNO_CALLBACK_URL=

# TypeORM
TYPEORM_SYNC=true
