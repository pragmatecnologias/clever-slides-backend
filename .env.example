NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pastor_decks
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=pastor_decks

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# LLM
LM_STUDIO_URL=http://localhost:1234/v1
OPENAI_API_KEY=

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# Media Generation APIs
ELEVENLABS_API_KEY=
SUNO_API_KEY=

# TypeORM
TYPEORM_SYNC=true
